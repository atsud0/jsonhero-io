type = "javascript"
compatibility_date = "2022-02-01"

account_id = "0cf692be2d4cc5827c7ba87ae5bc34ce"
workers_dev = true

kv_namespaces = [ 
  { binding = "DOCUMENTS", id = "4124fe171f0e4890b39fcfe7c931035e" }
]

[vars]
GRAPH_JSON_COLLECTION = "jsonhero-dev"

[site]
bucket = "./public"
entry-point = "."

[build]
command = "npm run build:worker"
watch_dir = "build/index.js"

[build.upload]
format="service-worker"

[env.production]
kv_namespaces = [ 
  { binding = "DOCUMENTS", id = "4124fe171f0e4890b39fcfe7c931035e" }
]

[env.production.vars]
GRAPH_JSON_COLLECTION = "jsonhero-prod"

# Secrets
# [SESSION_STORAGE]
# [GRAPH_JSON_API_KEY]
